import csv, json, time, os
from collections import Counter

THRESHOLDS = {
    "max_failed_tests": 0,
    "max_error_delta": 0.05,
    "max_latency_delta_pct": 0.50,
    "max_error_rate": 0.05,
}

SCENARIO_LAYER = {
    "S1": "delivery", "S2": "delivery",
    "S3": "deployment", "S4": "deployment", "S7": "deployment",
    "S5": "monitoring", "S6": "monitoring",
}

EXPECTED = {
    "S1": ["DEPLOY"], "S2": ["BLOCK"], "S3": ["CONTINUE"],
    "S4": ["ROLLBACK"], "S5": ["STABLE"],
    "S6": ["ROLLBACK", "INVESTIGATE"], "S7": ["ROLLBACK"],
}

def delivery_decision(row):
    failed = int(row["tests_failed"])
    gh = row["gh_actions_status"].strip().lower()
    if gh != "success":
        return "BLOCK", f"GitHub Actions statuss nav success: {gh}"
    if failed > THRESHOLDS["max_failed_tests"]:
        return "BLOCK", f"Neizturēti testi: {failed}/{row['tests_total']}"
    return "DEPLOY", f"Visi testi izturēti ({row['tests_passed']}/{row['tests_total']})"

def deployment_decision(row):
    ce = float(row["canary_error_rate"])
    se = float(row["stable_error_rate"])
    cl = float(row["canary_latency_ms"])
    sl = float(row["stable_latency_ms"])
    ed = ce - se
    ld = (cl - sl) / max(sl, 1)
    reasons = []
    if ed > THRESHOLDS["max_error_delta"]:
        reasons.append(f"Kļūdu delta {ed:.1%} > robeža {THRESHOLDS['max_error_delta']:.0%}")
    if ld > THRESHOLDS["max_latency_delta_pct"]:
        reasons.append(f"Latentuma pieaugums {ld:.0%} > robeža {THRESHOLDS['max_latency_delta_pct']:.0%}")
    if reasons:
        return "ROLLBACK", "; ".join(reasons)
    return "CONTINUE", f"Kļūdu delta {ed:.1%} un latentums {ld:.0%} pieļaujamās robežās"

def monitoring_decision(row):
    ce = float(row["canary_error_rate"])
    se = float(row["stable_error_rate"])
    ed = ce - se
    if ce > THRESHOLDS["max_error_rate"]:
        return "ROLLBACK", f"Kanārija kļūdu īpatsvars {ce:.1%} > robeža {THRESHOLDS['max_error_rate']:.0%}"
    if ed > THRESHOLDS["max_error_delta"]:
        return "ROLLBACK", f"Kļūdu delta {ed:.1%} > robeža {THRESHOLDS['max_error_delta']:.0%}"
    return "STABLE", f"Kļūdu īpatsvars {ce:.1%} pieļaujamās robežās"

def make_decision(row):
    layer = SCENARIO_LAYER[row["scenario_id"]]
    if layer == "delivery": return delivery_decision(row)
    if layer == "deployment": return deployment_decision(row)
    if layer == "monitoring": return monitoring_decision(row)

def run_baseline(input_csv, label):
    with open(input_csv, encoding="utf-8") as f:
        rows = list(csv.DictReader(f))
    results = []
    print(f"\n{'='*55}\nBASELINE: {label}\n{'='*55}")
    for sid in ["S1","S2","S3","S4","S5","S6","S7"]:
        srows = [r for r in rows if r["scenario_id"] == sid]
        ok = 0
        print(f"Scenārijs {sid}:", end=" ", flush=True)
        for row in srows:
            t0 = time.time()
            decision, reason = make_decision(row)
            elapsed = round(time.time() - t0, 6)
            correct = decision in EXPECTED[sid]
            if correct: ok += 1; print("✓", end="", flush=True)
            else: print("✗", end="", flush=True)
            ce = float(row["canary_error_rate"]); se = float(row["stable_error_rate"])
            cl = float(row["canary_latency_ms"]); sl = float(row["stable_latency_ms"])
            results.append({
                "experiment": label, "scenario_id": sid, "run_id": row["run_id"],
                "layer": SCENARIO_LAYER[sid],
                "baseline_decision": decision, "mi_decision": row["decision"],
                "baseline_correct": correct, "mi_correct": row["correct"] == "True",
                "baseline_reason": reason,
                "error_delta": round(ce - se, 4),
                "latency_delta_pct": round((cl - sl) / max(sl, 1), 4),
                "canary_error_rate": ce, "stable_error_rate": se,
                "canary_latency_ms": cl, "stable_latency_ms": sl,
                "tests_failed": row["tests_failed"],
                "baseline_time_s": elapsed, "mi_time_s": row["time_sec"],
            })
        print(f"  →  {ok}/{len(srows)} ({ok/len(srows)*100:.0f}%)")
    return results

def compute_stats(results, label):
    total = len(results); correct = sum(1 for r in results if r["baseline_correct"])
    by_scenario = {}
    for s in ["S1","S2","S3","S4","S5","S6","S7"]:
        sr = [r for r in results if r["scenario_id"] == s]
        sc = sum(1 for r in sr if r["baseline_correct"])
        by_scenario[s] = {"correct": sc, "total": len(sr),
            "accuracy_pct": round(sc/len(sr)*100, 1),
            "decisions": dict(Counter(r["baseline_decision"] for r in sr))}
    fp = sum(1 for r in results if not r["baseline_correct"]
             and r["baseline_decision"] in ["BLOCK","ROLLBACK"]
             and any(e in ["DEPLOY","CONTINUE","STABLE"] for e in EXPECTED[r["scenario_id"]]))
    fn = sum(1 for r in results if not r["baseline_correct"]) - fp
    return {
        "label": label, "total_runs": total, "correct": correct,
        "accuracy_pct": round(correct/total*100, 1),
        "by_scenario": by_scenario,
        "false_positives": fp, "false_negatives": fn,
        "consistency_pct": 100.0,
        "avg_decision_time_s": round(sum(r["baseline_time_s"] for r in results)/total, 6),
    }

def print_comparison(s1, s2):
    print(f"\n{'='*75}")
    print("SALĪDZINĀJUMS: MI AĢENTI vs NOTEIKUMU BĀZĒTĀ SISTĒMA")
    print(f"{'='*75}")
    print(f"{'Metrika':<38} {'E1-MI':>7} {'E1-BL':>7} {'E2-MI':>7} {'E2-BL':>7}")
    print(f"{'-'*75}")
    mi_e1 = {"accuracy_pct":91.4,"false_positives":0,"false_negatives":6,"consistency_pct":95.7,"avg_decision_time_s":9.6}
    mi_e2 = {"accuracy_pct":90.0,"false_positives":1,"false_negatives":7,"consistency_pct":87.1,"avg_decision_time_s":10.2}
    for lbl, key, unit in [
        ("Kopējā precizitāte (%)","accuracy_pct","%"),
        ("Viltus pozitīvi","false_positives",""),
        ("Viltus negatīvi","false_negatives",""),
        ("Konsekvence (%)","consistency_pct","%"),
        ("Vid. lēmuma laiks (s)","avg_decision_time_s","s"),
    ]:
        print(f"{lbl:<38} {str(mi_e1[key])+unit:>7} {str(s1[key])+unit:>7} {str(mi_e2[key])+unit:>7} {str(s2[key])+unit:>7}")
    print(f"\n{'Scenārijs':<8} {'E1-MI':>7} {'E1-BL':>7} {'E2-MI':>7} {'E2-BL':>7}")
    print(f"{'-'*40}")
    mi_s_e1 = {"S1":10,"S2":9,"S3":10,"S4":10,"S5":10,"S6":10,"S7":1}
    mi_s_e2 = {"S1":10,"S2":10,"S3":10,"S4":8,"S5":10,"S6":10,"S7":5}
    for s in ["S1","S2","S3","S4","S5","S6","S7"]:
        print(f"{s:<8} {mi_s_e1[s]:>4}/10 {s1['by_scenario'][s]['correct']:>4}/10 {mi_s_e2[s]:>4}/10 {s2['by_scenario'][s]['correct']:>4}/10")
    print(f"{'='*75}")

if __name__ == "__main__":
    for f in ["results_E1.csv","results_E2.csv"]:
        if not os.path.exists(f):
            print(f"KĻŪDA: Fails '{f}' nav atrasts!"); exit(1)
    r1 = run_baseline("results_E1.csv", "E1_baseline")
    r2 = run_baseline("results_E2.csv", "E2_baseline")
    s1 = compute_stats(r1, "E1_baseline")
    s2 = compute_stats(r2, "E2_baseline")
    all_r = r1 + r2
    with open("baseline_results.csv","w",newline="",encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=all_r[0].keys()); w.writeheader(); w.writerows(all_r)
    with open("baseline_stats.json","w",encoding="utf-8") as f:
        json.dump({"E1_baseline":s1,"E2_baseline":s2}, f, ensure_ascii=False, indent=2)
    print("\nRezultāti: baseline_results.csv | Statistika: baseline_stats.json")
    print_comparison(s1, s2)
